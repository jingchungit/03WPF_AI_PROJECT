<Application x:Class="WpfXamlPlayground.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:WpfXamlPlayground"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!--定义
        1.颜色画刷资源（SolidColorBrush）
        Brush.Primary	#3A7AFE	主色调（蓝色），用于主要按钮、强调元素
        Brush.PrimaryAlt	#00A88F	辅助主色（青绿色），用于次要强调
        Brush.Surface	#F4F6FB	背景色（浅灰蓝），用于窗口/卡片背景
        Brush.Border	#D7DCEC	边框色（灰蓝色），用于边框、分隔线
        2. 间距资源（Thickness）
        Spacing.CardPadding	16	卡片组件的内边距（上下左右均为 16px）
        3. 全局样式（Style）
        TargetType="TextBlock"	-	应用于所有 TextBlock 控件
        Margin="0,2,0,2"	-	上下留白 2px，左右 0
        Foreground="#223049"	深蓝灰色	统一文本颜色

        -->
        <SolidColorBrush x:Key="Brush.Primary" Color="Blue"/>
        <SolidColorBrush x:Key="Brush.PrimaryAlt" Color="#00A88F"/>
        <SolidColorBrush x:Key="Brush.Surface" Color="#F4F6FB"/>
        <SolidColorBrush x:Key="Brush.Border" Color="#D7DCEC"/>
        <Thickness x:Key="Spacing.CardPadding">16</Thickness>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Foreground" Value="#223049"/>
        </Style>
    </Application.Resources>
</Application>
<!--1. App.xaml 和 MainWindow.xaml 为什么同时存在？
文件	作用	生命周期
App.xaml	应用程序入口 + 全局资源	整个应用运行期间存在
MainWindow.xaml	主窗口界面	窗口打开期间存在-->
<!--App.xaml (应用程序级)
├── 应用启动配置
├── 全局资源 (颜色、样式、间距)
├── 事件处理 (启动、退出、异常)
└── 指定启动窗口

MainWindow.xaml (窗口级)
├── 窗口布局
├── 控件定义
├── 窗口级资源
└── 业务 UI 逻辑-->
<!--2. 为什么打开软件自动打开 MainWindow.xaml？
    在 App.xaml 中配置了 启动 URI：
    <Application x:Class="WpfXamlPlayground.App"
             ...
             StartupUri="MainWindow.xaml">
    
                ───────────────────────────────────┐
            │                    WPF 应用程序                       │
            ├─────────────────────────────────────────────────────┤
            │  App.xaml (应用程序入口)                             │
            │  ┌───────────────────────────────────────────────┐  │
            │  │ StartupUri="MainWindow.xaml"  ← 指定启动窗口   │  │
            │  │ Application.Resources ← 全局资源               │  │
            │  └───────────────────────────────────────────────┘  │
            │                        ↓ 启动时加载                  │
            │  ┌───────────────────────────────────────────────┐  │
            │  │  MainWindow.xaml (主窗口界面)                   │  │
            │  │  ┌─────────────────────────────────────────┐  │  │
            │  │  │  Window 根元素                           │  │  │
            │  │  │  控件布局 (Grid, Border, Button...)      │  │  │
            │  │  │  窗口级资源                              │  │  │
            │  │  └─────────────────────────────────────────┘  │  │
            │  └───────────────────────────────────────────────┘  │
            └─────────────────────────────────────────────────────┘
    -->