<Window x:Class="WpfXamlPlayground.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:WpfXamlPlayground.Controls"
        xmlns:converters="clr-namespace:WpfXamlPlayground.Converters"
        xmlns:helpers="clr-namespace:WpfXamlPlayground.Helpers"
        mc:Ignorable="d"
        Title="WPF XAML 全知识点练习"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource Brush.Surface}">
    <Window.Resources>
<!--Windwos 资源定义 -->
        <!--窗口级别的资源容器 样式、模板、转换器、画刷等可复用对象-->
        
        <!-- 定义样式 --><!--
        <Style x:Key="MyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Blue"/>
        </Style>

        --><!-- 定义转换器 --><!--
        <converters:BoolToStatusTextConverter x:Key="MyConverter"/>

        --><!-- 定义画刷 --><!--
        <SolidColorBrush x:Key="MyBrush" Color="Red"/>-->

        <!-- 使用 StaticResource 引用 --><!--
        <Button Style="{StaticResource MyButtonStyle}"/>

        --><!-- 使用 DynamicResource 引用 --><!--
        <Button Background="{DynamicResource MyBrush}"/>

        --><!-- 在绑定中使用转换器 --><!--
        <TextBlock Text="{Binding IsDone, Converter={StaticResource MyConverter}}"/>-->

        <!--1.命名空间映射，指向c#命名空间，实例化一个值转换器资源，converters命名空间通常存放实现了IValueConverter接口的类，用于在数据绑定过程中转换数据格式。-->
        <converters:BoolToStatusTextConverter x:Key="BoolToStatusTextConverter"/>
        <!--converters:BoolToStatusTextConverter	创建转换器实例
        x:Key="BoolToStatusTextConverter"	资源的唯一标识符-->

        <!--定义一个Card样式-->
        <Style x:Key="CardStyle" TargetType="Border">
            <!--定义Border的通用样式-->
            <Setter Property="Background" Value="White"/>
            <!--2.StaticResource vs DynamicResource
            标记扩展：静态资源引用，动态资源引用
            特性	StaticResource	DynamicResource
            查找时机	XAML 加载时一次性查找	    运行时动态查找
            性能	更高（缓存结果）                        	稍低（支持变化）
            响应变化	❌ 资源变化不更新	✅       资源变化自动更新 运行时每次需要时查找
            适用场景	固定样式、间距	主题色、        动态样式 资源变化 → 自动更新 UI

            -->
            <Setter Property="Padding" Value="{StaticResource Spacing.CardPadding}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Margin" Value="8"/>
            <!--3.Triggers 是 WPF 中的 触发器，用于根据条件 动态改变样式属性。
            Trigger	触发器，监听某个属性的变化
            Style.Triggers	样式触发器集合，定义在 Style 中
            Setter	当触发条件满足时，应用的属性设置
                1. Property Trigger（属性触发器）- 当前使用
                比如 IsMouseOver 属性，当鼠标移入按钮时，按钮的边框颜色变蓝
                2. Data Trigger（数据触发器）
                比如 TextBox 的 Text 属性，当输入内容时，按钮的背景颜色变绿
                3. Event Trigger（事件触发器）
                比如 Button 的 Click 事件，当点击按钮时，按钮的背景颜色变红
                4. Multi Trigger（多条件触发器）
                比如 TextBox 的 Text 、IsEnabled 属性，当输入内容、按钮可用时，按钮的背景颜色变黄
            -->
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Primary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <!--定义Button的样式-->
            <Setter Property="Foreground" Value="Blue"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="BorderThickness" Value="0"/>
            
            <Setter Property="Template">
                <!--4.Template控件模板，创建Button的模板
                Template	控件模板属性，定义控件的视觉结构
                ControlTemplate	模板的具体内容，替换控件默认外观
                TargetType	模板应用的目标控件类型

                -->
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <!--1. TemplateBinding（模板绑定） 将模板内部属性绑定到控件外部属性	，
                            让用户可以设置 Button 的 Background 等属性
                            3. 命名元素ButtonBorder（用于触发器）给模板内元素命名	在 Trigger 中通过 TargetName 引用
-->
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                            <!--2. ContentPresenter（内容呈现器） 显示控件的内容	如 Button 的 Content="按钮文字"
-->

                        </Border>
                        <ControlTemplate.Triggers>
                            <!--<ControlTemplate.Triggers>是 控件模板内部的触发器集合，用于在模板内根据条件动态改变模板元素的属性。-->
                                <!--鼠标移入时，按钮变暗 悬停-->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.86"/>
                            </Trigger>
                            <!--鼠标按下时，按钮变小-->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <!--5. Transform 是 WPF 中的 几何变换，用于对 UI 元素进行缩放、旋转、平移等操作。
                                    RenderTransform RenderTransform	渲染变换属性，改变元素的视觉呈现
                                    缩放	ScaleTransform	放大/缩小	ScaleX="0.98"
                                    旋转	RotateTransform	绕点旋转	Angle="45"
                                    平移	TranslateTransform	位置移动	X="10" Y="20"
                                    倾斜	SkewTransform	倾斜变形	AngleX="10"
                                    组合	TransformGroup	多个变换组合	包含以上多种
                                    
                                    RenderTransform vs LayoutTransform
                                    特性	RenderTransform	LayoutTransform
                                    影响布局	❌ 不影响其他元素布局	✅ 影响布局
                                    性能	更高（仅视觉变换）	稍低（需重新布局）
                                    适用场景	动画、交互效果	需要改变元素占位

                                    -->
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <!--鼠标-->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
                
            </Setter>
        </Style>
<!--
            DataTemplate	数据模板，定义数据如何显示
            作用	将数据对象转换为 UI 元素
            使用场景	ListBox、ListView、ComboBox 等 ItemsControl 的项显示-->
        <!--DataTemplate 是什么？	数据模板，定义数据对象的可视化呈现方式
                和 ControlTemplate 区别？	DataTemplate 用于数据，ControlTemplate 用于控件
                当前项目作用？	定义任务项的卡片显示样式
                常用场景？	ListBox、ListView、ComboBox 等列表控件的项显示-->

        <DataTemplate x:Key="TaskTemplate">
            <!--使用CardStyle样式
            helpers:HoverHelper.HighlightOnHover="True" 是 WPF 中的 附加属性（Attached Property） 用法，用于给元素添加悬停高亮效果。
            helpers	命名空间前缀，指向 WpfXamlPlayground.Helpers
            HoverHelper	辅助类名
            HighlightOnHover	该类定义的附加属性="True"	启用悬停高亮功能
            什么是附加属性？
            附加属性允许 给对象添加原本没有的属性，无需修改类本身。
            
            与 Style.Triggers 对比
            方式	代码位置	灵活性
            Style.Triggers	XAML 中定义	样式固定
            HoverHelper	C# 代码实现	可复用、可扩展

            -->
            <Border Style="{StaticResource CardStyle}"
                    helpers:HoverHelper.HighlightOnHover="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="14" FontWeight="SemiBold" Text="{Binding Title}"/>
                        <TextBlock Foreground="#60718B" Text="{Binding IsDone, Converter={StaticResource BoolToStatusTextConverter}}"/>
                        <!--绑定isDone属性，使用资源中定义的转换处理器绑定值，使isDone转换为可读的状态文本再显示-->
                        <!--使用方式
                                1.定义转换器类
                                2.再XAMK中声明
                                3.绑定中引用转换器
                                目标属性：就是TextBlock
                                -->
                    </StackPanel>
                    
                    <!--自定义控件，评分勋章，继承自Control类-->
                    <!--controls: 是命名空间前缀，指向 WpfXamlPlayground.Controls 命名空间-->
                    <!--BadgeBrush="{DynamicResource Brush.Primary}" - 动态主题色绑定-->
                         <!--BadgeBrush：控件的依赖属性，控制徽章的背景颜色-->
                         <!--{DynamicResource Brush.Primary}：使用动态资源引用获取主题色-->
                            <!--与 StaticResource 不同，DynamicResource 会在运行时响应资源变更-->
                    <!--Score="{Binding Priority, StringFormat={}{0}0}" - 数据绑定 + 格式化-->
                        <!--{0} 是占位符，代表绑定的值
                        后面的 0 是格式说明符，表示乘以 10（例如 Priority=5 显示为 50）
                        第一个 {} 是转义符，告诉 XAML 解析器后面的是格式字符串-->
                    <controls:RatingBadge Grid.Column="1"
                                          Margin="8,0,0,0"
                                          BadgeBrush="{DynamicResource Brush.Primary}"
                                          Score="{Binding Priority, StringFormat={}{0}0}"/>
                </Grid>
            </Border>
            
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <!--定义三行两列-->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!--默认第0行第0列-->
        <Border Grid.ColumnSpan="2" Style="{StaticResource CardStyle}">
            <!--横跨两列，Border卡片样式容器，StaticResource样式引用-->
            <DockPanel LastChildFill="False">
                <!--DockPanel布局容器，作用	按上下左右停靠方式布局子元素，类似CSS的float和flex，按照Xaml的顺序依次停靠-->
                <!--LastChildFill:True True（默认）	最后一个元素自动填充剩余空间,False:最后一个元素按实际大小显示-->
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           FontSize="22"
                           FontWeight="Bold"
                           Text="WPF XAML 综合练习场"/>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnSwitchThemeClick"
                        Content="第一样切换 DynamicResource 主题色"/>
                <!--Click 事件处理-->
            </DockPanel>
        </Border>

        <!--第2行第0列-->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <!--•	StackPanel：默认垂直堆叠子元素，用于排列表单控件。-->
                <TextBlock FontWeight="Bold" FontSize="16" Text="绑定 / 命令 / 输入"/>
                <TextBox Margin="0,8,0,0"
                         Text="{Binding NoteText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                <!--•	ToolTip：利用绑定动态显示提示内容，增强用户体验。-->
                
                <!--数据绑定 (Data Binding)-->
                <!--默认 DataContext 绑定：Text="{Binding NoteText}"，绑定到当前数据上下文（ViewModel）的属性。-->
                <!--•	绑定模式与触发：
                •	Mode=TwoWay：双向绑定，数据变更互相同步。
                •	UpdateSourceTrigger=PropertyChanged：属性一旦变化立即更新源，而非默认失去焦点时更新。-->
                
                <TextBlock Foreground="#5B6C85"
                           Text="{Binding ElementName=InputLengthBar, Path=Value, StringFormat=长度阈值：{0:F0}}"/>
                <!--•	元素名称绑定 (ElementName)：Text="{Binding ElementName=InputLengthBar,Path=Value}"，直接绑定到同一窗口内另一个控件（Slider）的属性。-->
                <!--•	字符串格式化：StringFormat=长度阈值：{0:F0}，在绑定结果中添加前缀并格式化数字（保留 0 位小数）。-->

                <Slider x:Name="InputLengthBar"
                        Margin="0,4,0,0"
                        Minimum="1"
                        Maximum="50"
                        Value="10"/>
                <!--•	Slider 控件：通过 Minimum、Maximum、Value 设置范围滑块，用于输入数值阈值。-->
                <!--•	x:Name，作用：为 XAML 中的对象元素分配一个名称。
                •	x:Class：指定代码后台类名（如 MainWindow）。
                •	x:Key：为资源字典中的对象指定唯一键（如 BoolToStatusTextConverter）。
                •	x:Static：引用静态成员。-->
                
                <WrapPanel Margin="0,10,0,0">
                    <!--•	WrapPanel：子元素按顺序排列，空间不足时自动换行，常用于按钮组。-->
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddTaskCommand}"
                            Content="新增任务"/>
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding CompleteSelectedCommand}"
                            Content="完成选中任务"/>
                </WrapPanel>
                <!--命令与交互 (Command & Interaction)-->
                <!--•	命令绑定：Command="{Binding AddTaskCommand}"，将按钮点击事件绑定到 ViewModel 中的命令对象（ICommand），符合 MVVM 模式，实现逻辑与界面分离。-->
                <!--•	事件驱动：通过命令触发“新增任务”、“完成选中”、“广播消息”等业务逻辑。-->


                <Separator Margin="0,10,0,10"/>
                <!--•	Separator：用于视觉上的分隔线，区分不同功能区域（如“绑定/命令”与“广播消息”）。-->
                
                <!--TODO 广播与订阅发布-->
                <TextBlock FontWeight="Bold" Text="广播消息（发布-订阅）"/>
                <TextBox Margin="0,6,0,0"
                         Text="{Binding BroadcastText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Width="120"
                        HorizontalAlignment="Left"
                        Command="{Binding BroadcastMessageCommand}"
                        Content="广播消息"/>
                
                <TextBlock Margin="0,6,0,0" Foreground="#2F4A72" Text="{Binding ReceiverA}"/>
                <TextBlock Foreground="#2F4A72" Text="{Binding ReceiverB}"/>
            </StackPanel>
        </Border>

        <!--第2行第2列-->
        <!--1. 事件触发器 (EventTrigger)-->
        <!--•	区别：之前使用的是 Style.Triggers 中的 Property Trigger（监听属性变化，如 IsMouseOver）。-->
        <!--•	新知：这里使用 Button.Triggers 中的 EventTrigger，监听 路由事件（RoutedEvent="Button.Click"），点击按钮时触发动画。-->
        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="16" Text="触发器 / 动画"/>
                <ProgressBar x:Name="LearningProgress"
                             Margin="0,12,0,6"
                             Height="20"
                             Maximum="100"
                             Value="30"/>
                <!--引入进度条控件，并设置初始值 30。-->
                
                <Button Content="播放进度动画"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="140"
                        HorizontalAlignment="Left">
                    <Button.Triggers>
                        <!--•	RoutedEvent：是 EventTrigger 的属性，用于指定要监听的路由事件-->
                        <!--•	Button.Click：是一个具体的路由事件，表示按钮被点击时触发-->
                        <!--点击按钮 → Button → 父容器 (Border/StackPanel) → 更上层容器 → Window
                         ↑
                       事件源-->
                        
                        <EventTrigger RoutedEvent="Button.Click">
                            <!--1.路由事件：
                            特性	说明
                            定义	事件可以在父子元素之间传递传播
                            目的	允许父元素处理子元素的事件，实现事件集中管理
                            对比	普通 .NET 事件只在触发元素上响应-->
                            <!--2. 三种路由策略-->
                            <!--策略	方向	说明	示例
                            ①冒泡 (Bubble)	子 → 父	事件从源元素向上逐级传递	Button.Click
                                    父容器可以捕获子元素的事件
                                    <Grid Button.Click="OnAnyButtonClick">
                                    <Button Content="按钮 1"/>
                                    <Button Content="按钮 2"/>
                                </Grid>
                            // MainWindow.xaml.cs
                                private void OnAnyButtonClick(object sender, RoutedEventArgs e)
                                {
                                    // 可以处理 Grid 内所有 Button 的点击事件
                                }
                            ② 隧道 (Tunnel)	父 → 子	事件从根元素向下逐级传递	PreviewKeyDown
                                        <Window PreviewKeyDown="OnPreviewKeyDown">
                                            <TextBox/>
                                        </Window>
                            // MainWindow.xaml.cs
                                private void OnPreviewKeyDown(object sender, KeyEventArgs e)
                                {
                                    // 在 TextBox 收到按键之前先处理
                                    if (e.Key == Key.Space)
                                    {
                                        e.Handled = true; // 阻止事件继续传播，禁止输入空格 标记事件是否已被处理
                                    }
                                }
                            隧道事件通常以 Preview 开头：
                            •	PreviewKeyDown (隧道) vs KeyDown (冒泡)
                            •	PreviewMouseDown (隧道) vs MouseDown (冒泡)
                            •	PreviewTextInput (隧道) vs TextInput (冒泡)
                            ③直接 (Direct)	仅源元素	类似普通 .NET 事件	MouseEnter-->
                            <!--<Border MouseEnter="OnBorderMouseEnter">
                                --><!-- MouseEnter 是直接事件，不会冒泡到父元素 --><!--
                            </Border>-->
                            
                            
                            <!--3. 代码中的示例
                                <EventTrigger RoutedEvent="Button.Click">
                            •	Button.Click 是一个 冒泡路由事件
                            •	点击按钮后，事件会沿着元素树向上冒泡
                            •	父容器（如 Grid、Window）也可以监听并处理这个事件-->
                            <!--4. 常见路由事件-->
                            <!--事件	路由策略	说明
                            Click	冒泡	按钮点击
                            MouseDown	冒泡	鼠标按下
                            KeyDown	冒泡	键盘按下
                            PreviewKeyDown	隧道	键盘按下（预览）
                            MouseEnter	直接	鼠标进入（不冒泡）-->
                            
                            
                            <!--代码注册自定义事件-->
                            <!--注册一个冒泡路由事件
                            public static readonly RoutedEvent MyEvent = EventManager.RegisterRoutedEvent(
                                "MyEvent", 
                                RoutingStrategy.Bubble, // 指定路由策略
                                typeof(RoutedEventHandler), 
                                typeof(MyControl)
                            );-->
                            <!--// 添加事件处理程序
                            this.AddHandler(MyEvent, new RoutedEventHandler(OnMyEvent));-->

                            <BeginStoryboard>
                                <!--启动动画-->
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="LearningProgress"
                                                     Storyboard.TargetProperty="Value"
                                                     To="95"
                                                     Duration="0:0:1.2"/>
                                    <!--动画容器/故事板-->
                                    <!--TargetName	LearningProgress	动画作用的控件名称（对应 ProgressBar 的 x:Name）
                                    TargetProperty	Value	动画作用的具体属性（进度条的当前值）-->


                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Button.Triggers>
                </Button>
                <!--2. 故事板与动画 (Storyboard & Animation)-->
                <!--<Storyboard>是动画的容器，用于组织和管理一系列动画效果。-->
                <!--<BeginStoryboard>动作用于启动故事板。-->
                <!--DoubleAnimation：具体的动画类型，用于对 double 类型的属性（如进度条的 Value）进行平滑过渡。-->
                <!--•	To="95"：动画结束时的目标值。
                      •	Duration="0:0:1.2"：动画持续时间（格式为 时：分：秒）。-->
                <!--3. 动画目标定位-->
                <!--•	Storyboard.TargetName="LearningProgress"：指定动画作用的具体控件（通过 x:Name 查找）。-->
                <!--•	Storyboard.TargetProperty="Value"：指定动画作用的具体依赖属性。-->


                    <TextBlock Margin="0,8,0,0"
                           Text="{Binding ElementName=LearningProgress, Path=Value, StringFormat=当前进度: {0:F0}%}"/>
                <!--参数：ElementName: 指定动画作用具体控件（通过 x:Name 绑定）。
                Path: 指定动画作用具体依赖属性。
                StringFormat: 格式化字符串，用于控制输出的格式。
                {0}	占位符，替换为绑定值	30 或 95
                :F0	格式说明符，保留 0 位小数	30.0 → 30-->
                
                <!--Binding 常用属性大全
                Path	绑定路径	Path=Value
                ElementName	元素名称绑定	ElementName=LearningProgress
                Mode	绑定模式	Mode=TwoWay
                UpdateSourceTrigger	更新触发	UpdateSourceTrigger=PropertyChanged
                StringFormat	字符串格式化	StringFormat={}{0:F0}%
                Converter	值转换器	Converter={StaticResource MyConverter}
                FallbackValue	失败备用值	FallbackValue=0
                TargetNullValue	空值备用值	TargetNullValue=暂无
                ElementName=LearningProgress	元素名称绑定	绑定到同一窗口内的控件
                Path=Value	属性路径绑定	绑定到控件的 Value 属性
                Text="{Binding NoteText}"	DataContext 绑定	绑定到 ViewModel 属性
                Command="{Binding AddTaskCommand}"	命令绑定	绑定到 ICommand-->
                
                <!--DataContext = 绑定的"默认查找位置"

                就像你去图书馆找书：
                - 有 DataContext：直接在"当前书架"找（默认位置）
                - 无 DataContext：需要指定"去哪个书架"找（如 ElementName）-->

            </StackPanel>   
        </Border>

        <!--第2行第1列-->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource CardStyle}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,8"
                           Text="ItemsControl / GroupStyle / DataTemplate"/>
                <!--使用-->
                <!--1. ListBox 数据绑定-->
                <!--1. ListBox 数据绑定
                属性	作用	说明
                            1. **`ItemsSource="
                                项目	说明
                                作用	指定 ListBox 显示的数据集合
                                绑定方式	绑定到 ViewModel 的 TaskView 属性
                                数据类型	通常是 IEnumerable、List<T>、ObservableCollection<T> 等集合
                            2. **`ItemTemplate="
                                项目	说明
                                作用	定义每条数据如何显示成 UI
                                引用方式	引用 Window.Resources 中定义的 TaskTemplate 卡片样式
                                类型	DataTemplate
                                效果：集合中的每个 TaskItem 对象都会按这个模板渲染成一个卡片
                            3. SelectedItem="{Binding SelectedTask, Mode=TwoWay}" - 选中项
                                项目	说明
                                作用	绑定当前选中的列表项
                                绑定模式	TwoWay 双向绑定
                                数据流向	用户选择 → 更新 ViewModel / ViewModel 改变 → 更新 UI 选中状态
                            4. AlternationCount="2" - 交替计数
                                项目	说明
                                作用	设置交替循环的周期数量
                                配合属性	AlternationIndex（每项的交替索引）
                                常见用途	隔行变色、奇偶行不同样式
                
                SelectedItem	选中项绑定	Mode=TwoWay 实现双向同步
                ItemTemplate	项模板	引用之前定义的 TaskTemplate DataTemplate-->
                
                <!--2.AlternationCount（交替计数）-->
                <!--•	作用：让列表项按指定数量循环交替
                •	用途：可实现隔行变色效果（配合 AlternationIndex）
                •	当前值：2 表示每 2 行一个循环-->
                <ListBox ItemsSource="{Binding TaskView}"
                         ItemTemplate="{StaticResource TaskTemplate}"
                         SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                         AlternationCount="2">
                    
                    <!--3. ItemContainerStyle（项容器样式）-->
                    <!--3.1在 ListBox 中，每一项数据都会被包裹在一个容器中，这个容器就是 ListBoxItem。-->
                            <!--3. 2. ItemContainerStyle vs ItemTemplate-->
                            <!--对比项	ItemContainerStyle	ItemTemplate
                            作用对象	ListBoxItem 容器	数据本身
                            控制内容	边距、选中状态、对齐方式	数据如何显示成 UI
                            类比	相框的样式	照片的内容
                            常用属性	Margin、Background、IsSelected	Text、Binding、Converter-->

                    <ListBox.ItemContainerStyle>
                        <!--•	知识点：ListBoxItem 是 ListBox 每项的容器，可单独设置样式-->
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="0,4,0,4"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <!--•	Trigger：监听 IsSelected 属性，选中时改变背景色-->
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#DDE8FF"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    
                    
                    <!--4. GroupStyle（分组样式） ⭐ 重点-->
                    <!--•	作用：将列表项按某个属性分组显示
                    •	HeaderTemplate：定义每组标题的显示模板
                    •	绑定：{Binding Name} 绑定到分组依据的属性-->
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <!--HeaderTemplate	✅ 最常用！定义每组标题（如“工作”、“学习”）的 UI 模板
                            ContainerStyle	定义整个分组容器（包含标题+所有项）的样式
                            Panel	控制组内项的布局方式-->

                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,10,0,4"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               Foreground="{DynamicResource Brush.Primary}"
                                               Text="{Binding Name, StringFormat=分类: {0}}"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</Window>
